{
  "name": "boarding-ledger",
  "private": true,
  "version": "0.1.1",
  "description": "Victoria Residence — dormitory / boarding house management desktop app",
  "author": "Victoria Residence",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "electron:build": "tsc -b && vite build && electron-builder",
    "electron:release": "tsc -b && vite build && electron-builder --publish always"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.4",
    "electron-updater": "^6.8.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "@types/react": "^18.3.10",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^32.1.2",
    "electron-builder": "^25.0.5",
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "vite-plugin-electron": "^0.28.8"
  },
  "main": "dist-electron/main.js",
  "build": {
    "appId": "com.boardingledger.app",
    "productName": "Victoria Residence",
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "publish": {
      "provider": "github",
      "owner": "Poink1006",
      "repo": "boarding-ledger",
      "releaseType": "release"
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.business"
    },
    "win": {
      "target": "nsis"
    }
  }
}
